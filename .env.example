# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.3

# ── 감정 분류 모델 ────────────────────────────────────────
SENTIMENT_MODEL_NAME=klue/roberta-base
SENTIMENT_MODEL_PATH=saved_models/sentiment_best.pt
NUM_LABELS=3
# 0=부정(Negative) / 1=중립(Neutral) / 2=긍정(Positive)

# ── 학습 하이퍼파라미터 ───────────────────────────────────
TRAIN_EPOCHS=5
TRAIN_BATCH_SIZE=32
TRAIN_LR=2e-5
TRAIN_MAX_LEN=128
TRAIN_WARMUP_RATIO=0.1

# ── RAG 벡터스토어 ────────────────────────────────────────
VECTORSTORE_PATH=data/vectorstore
KNOWLEDGE_BASE_DIR=knowledge_base
TOP_K_RETRIEVAL=3
EMBEDDING_MODEL=text-embedding-3-small

# ── 챗봇 서비스 ──────────────────────────────────────────
MAX_HISTORY_TURNS=10
ESCALATION_THRESHOLD=0.7
# 부정 감정 확률이 이 값을 넘으면 상담원 연결 권고

# ── 서버 ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
GRADIO_PORT=7860
GRADIO_SHARE=false
